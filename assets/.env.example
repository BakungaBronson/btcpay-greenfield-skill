# Copy this file to ".env" (next to your scripts) and fill it in.
# Load it with: `set -a; source .env; set +a`  (or use python-dotenv).
# NEVER commit the real .env. Add it to .gitignore.

# Your BTCPay Server instance (no trailing slash).
BTCPAY_HOST=https://your.btcpay.tld

# An API key scoped to the MINIMUM permissions you need, and to ONE store.
# Create it in the UI: Account -> Manage account -> API keys.
BTCPAY_API_KEY=

# The store these credentials act on.
BTCPAY_STORE_ID=

# The secret returned when you create a webhook (client.create_webhook).
# Required by webhook_server.py to verify incoming deliveries.
BTCPAY_WEBHOOK_SECRET=

# Optional: port for the local webhook server (default 8080).
PORT=8080
